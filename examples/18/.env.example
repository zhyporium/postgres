POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Run scripts/pin-example-images.sh after CI publishes to refresh the digest
POSTGRES_IMAGE=ghcr.io/zhyporium/postgres:18@sha256:59bdff27cd49aed7f75d6bad201ec2513ce84ab72d6ad5416ebc3dd7fadb037e

# Optional: enable self-signed TLS (remote clients must use sslmode=require)
# POSTGRES_SSL=1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?schema=public
# With POSTGRES_SSL=1: postgresql://postgres:postgres@localhost:5432/postgres?schema=public&sslmode=require
# Same Compose network: postgresql://postgres:postgres@postgres:5432/postgres?schema=public
